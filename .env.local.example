# ─────────────────────────────────────────────────────────────────────────────
# Tiba Render Studio — Environment Variables
# Copy this file to .env.local and fill in your keys before running the app.
# ─────────────────────────────────────────────────────────────────────────────

# Your Google Gemini API key (used for image generation)
# Get one at: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here

#── Optional: override the Gemini models used ────────────────────────────────
# These defaults work out of the box. Only change if you want to use a newer model.

# Model used for quick preview renders (Stages 1 and 3)
GEMINI_FLASH_MODEL=gemini-2.0-flash-exp-image-generation

# Model used for the final high-quality render (Stage 4)
GEMINI_PRO_MODEL=gemini-2.0-flash-exp-image-generation
